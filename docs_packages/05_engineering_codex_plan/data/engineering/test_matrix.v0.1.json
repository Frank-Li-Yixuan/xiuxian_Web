{
  "version": "0.1",
  "commands": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:determinism": "vitest run tests/determinism",
    "validate:data": "tsx tools/validate-data.ts",
    "check:forbidden": "node scripts/check-forbidden-patterns.mjs"
  },
  "gates": [
    {
      "name": "repository_smoke",
      "commands": [
        "typecheck",
        "test"
      ]
    },
    {
      "name": "gameplay_change",
      "commands": [
        "typecheck",
        "test",
        "test:determinism",
        "validate:data",
        "check:forbidden"
      ]
    },
    {
      "name": "netcode_change",
      "commands": [
        "typecheck",
        "test:determinism",
        "test:net:two-client"
      ]
    }
  ]
}