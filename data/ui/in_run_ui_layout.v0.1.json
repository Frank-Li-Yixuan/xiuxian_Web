{
  "id": "in_run_ui_layout_v0_1",
  "name": "局内 UI/UX 信息架构 v0.1 布局",
  "targetResolution": {
    "width": 1920,
    "height": 1080
  },
  "scaling": {
    "baseScale": 1.0,
    "supportedScales": [
      0.85,
      1.0,
      1.15,
      1.3
    ],
    "minSupportedResolution": {
      "width": 1600,
      "height": 900
    }
  },
  "zones": {
    "leftDaoPanel": {
      "x": 0,
      "y": 0,
      "width": 360,
      "height": 1080,
      "purpose": "玩家生命、真元、灵气经验、法术、功法/天赋摘要"
    },
    "centerCombat": {
      "x": 360,
      "y": 0,
      "width": 1080,
      "height": 1080,
      "purpose": "核心战斗区：玩家、弹幕、敌人、掉落、雷劫落点"
    },
    "rightExternalPanel": {
      "x": 1440,
      "y": 0,
      "width": 480,
      "height": 1080,
      "purpose": "修为、丹药、本命法宝、灵宝、队友/救援状态"
    },
    "topCenterShared": {
      "x": 560,
      "y": 16,
      "width": 800,
      "height": 96,
      "purpose": "团队灵气经验、Boss 血条、阶段提示"
    },
    "bottomCenterPrompts": {
      "x": 560,
      "y": 900,
      "width": 800,
      "height": 120,
      "purpose": "短提示、救援提示、连携提示"
    }
  },
  "componentPlacement": {
    "PlayerCorePanel.p1": {
      "zone": "leftDaoPanel",
      "anchor": "top",
      "order": 1
    },
    "TeamInsightBar": {
      "zone": "topCenterShared",
      "anchor": "top",
      "order": 1
    },
    "SpellBar.p1": {
      "zone": "leftDaoPanel",
      "anchor": "middle",
      "order": 3
    },
    "BuildSummary.p1": {
      "zone": "leftDaoPanel",
      "anchor": "bottom",
      "order": 4
    },
    "CultivationBar.p1": {
      "zone": "rightExternalPanel",
      "anchor": "top",
      "order": 1
    },
    "PillBar.p1": {
      "zone": "rightExternalPanel",
      "anchor": "middle",
      "order": 2
    },
    "ArtifactPanel.p1": {
      "zone": "rightExternalPanel",
      "anchor": "middle",
      "order": 3
    },
    "SpiritTreasureRack.p1": {
      "zone": "rightExternalPanel",
      "anchor": "bottom",
      "order": 4
    },
    "BossHud": {
      "zone": "topCenterShared",
      "anchor": "top",
      "order": 0,
      "visibleWhen": "bossActive"
    },
    "TribulationOverlay": {
      "zone": "centerCombat",
      "anchor": "top",
      "order": 0,
      "visibleWhen": "tribulationActive"
    },
    "InsightOverlay": {
      "zone": "fullScreen",
      "anchor": "center",
      "order": 0,
      "visibleWhen": "insightPaused"
    },
    "RescuePrompt": {
      "zone": "bottomCenterPrompts",
      "anchor": "center",
      "order": 0,
      "visibleWhen": "rescueAvailable"
    }
  },
  "combatSafeArea": {
    "playerHighFrequencyArea": {
      "x": 360,
      "y": 720,
      "width": 1080,
      "height": 300
    },
    "noPersistentPanelArea": {
      "x": 420,
      "y": 620,
      "width": 960,
      "height": 380
    }
  }
}