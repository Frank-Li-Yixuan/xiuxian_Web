    "ifSixMonthBudgetHigh": {
      "breath": -2,
      "growth": 2,
      "omen": 4,
      "thread": 6,
      "pressure": 4,
      "choice_seed": 3,
      "transition_seed": 2
    }
  },
  "selectionGuards": [
    "eligible ageMonthRange",
    "conditions pass",
    "cooldown pass",
    "not over maxTriggersPerLife",
    "hidden true names never exposed in visible log"
  ]
