{
  "schemaVersion": "0.1.0",
  "mode": "lockstep_with_host_snapshot_repair",
  "rollbackPrediction": {
    "enabledInV0_1": false,
    "reservedForV0_2": true,
    "notes": "v0.1 不做高频 rollback 预测，只保留 snapshot + input history 以支持重连和不同步修复。"
  },
  "inputDelay": {
    "defaultFrames": 4,
    "adaptive": true,
    "rttBands": [
      { "maxRttMs": 50, "frames": 3 },
      { "maxRttMs": 90, "frames": 4 },
      { "maxRttMs": 140, "frames": 6 },
      { "maxRttMs": 200, "frames": 9 }
    ]
  },
  "hashing": {
    "hashEveryFrames": 120,
    "mismatchConfirmCount": 2,
    "logCanonicalStateOnMismatch": true
  },
  "snapshotRepair": {
    "enabled": true,
    "authority": "host",
    "snapshotEveryFrames": 120,
    "snapshotRingSize": 180,
    "resimulateInputHistory": true,
    "maxRepairAttemptsPerRun": 3
  },
  "disconnect": {
    "networkWaitingPause": true,
    "timeoutMs": 5000,
    "reconnectGraceMs": 60000,
    "afterGracePolicy": "host_may_continue_with_absent_player_soul_offline"
  }
}
